  "risk_thresholds": {
    "profit_decline_pct": 20,
    "revenue_decline_pct": 15,
    "roe_min": 5,
    "debt_ratio_max": 70
  },
  
  "notification": {
    "enabled": true,
    "channels": ["console", "email"],
    "wechat": {
      "enabled": false,
      "send_key": ""
    },
    "email": {
      "enabled": true,
      "recipients": ["longbow_max@163.com"],
      "daily_report_time": "15:30",
      "weekly_report_day": "Friday",
      "weekly_report_time": "18:00"
    }
  },
  
  "macro_monitor": {
    "enabled": true,
    "alert_on_major_change": true,
    "indicators": ["CPI", "PPI", "PMI", "money_supply"]
  },
  
  "analysis": {
    "fundamental": {
      "enabled": true,
      "check_express": true,
      "check_forecast": true
    },
    "technical": {
      "enabled": true,
      "indicators": ["MA", "MACD", "RSI", "BOLL"]
    },
    "fund_flow": {
      "enabled": true,
      "track_main_force": true,
      "track_northbound": true
    },
    "news": {
      "enabled": true,
      "keywords": ["重组", "并购", "解禁", "减持", "诉讼", "处罚", "政策", "订单"],
      "max_news_per_stock": 5
    },
    "valuation": {
      "enabled": true,
      "compare_with_industry": true,
      "pe_percentile_lookback_years": 5
    }
  },
  
  "report": {
    "generate_charts": true,
    "chart_days": 60,
    "save_html": true,
    "html_retention_days": 30
  },
  
  "tushare": {
    "token": null,
    "token_env_var": "TUSHARE_TOKEN"
  }
}
